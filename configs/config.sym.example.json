{
  "schema_version": "0.1",
  "project_name": "CryptoFlow-Sym example",
  "topic": "AES block cipher security evaluation and cryptanalysis survey",
  "mode": "example_template",
  "primary_domain": "symmetric_cryptography",
  "scope_policy": {
    "primary_scope": "symmetric_cryptography",
    "policy": "symmetric_first_not_symmetric_only",
    "default_out_of_scope": [
      "public_key_cryptography",
      "post_quantum_cryptography",
      "zero_knowledge",
      "secure_multiparty_computation",
      "fully_homomorphic_encryption",
      "protocol_only_topics_without_symmetric_core"
    ],
    "allowed_cross_scope_when": [
      "the symmetric primitive/component/construction is the core object",
      "the cross-scope item is only needed to interpret a symmetric construction, attack, implementation, benchmark, or standard"
    ],
    "cross_scope_required_fields": [
      "symmetric_core_object",
      "why_relevant_to_symmetric_crypto",
      "kept_sections",
      "discarded_sections"
    ]
  },
  "symmetric": {
    "research_task": "security_evaluation",
    "primitive_family": "block_cipher",
    "primitive_type": "spn_block_cipher",
    "target_primitives": [
      "AES"
    ],
    "allowed_primitive_families": [
      "block_cipher",
      "tweakable_block_cipher",
      "stream_cipher",
      "hash_function",
      "compression_function",
      "permutation",
      "sponge_construction",
      "duplex_construction",
      "xof",
      "aead",
      "authenticated_encryption_mode",
      "mac",
      "mode_of_operation",
      "prf",
      "prp",
      "sbox",
      "boolean_function",
      "vectorial_boolean_function",
      "sequence",
      "keystream_generator"
    ],
    "allowed_research_tasks": [
      "cryptanalysis",
      "component_theory",
      "construction",
      "design_analysis",
      "security_evaluation",
      "standardization_analysis",
      "automated_search",
      "modeling_method",
      "implementation_analysis",
      "artifact_reproduction",
      "benchmarking",
      "proof_or_security_argument",
      "survey"
    ],
    "allowed_claim_types": [
      "distinguisher",
      "key_recovery",
      "structural_property",
      "component_construction",
      "component_property",
      "security_bound",
      "attack_improvement",
      "complexity_claim",
      "security_evaluation",
      "standardization_claim",
      "modeling_result",
      "implementation_result",
      "reproduction_result",
      "negative_result",
      "survey_conclusion"
    ]
  },
  "literature": {
    "local_paths": [
      "papers/"
    ],
    "default_sources": [
      "local_papers",
      "IACR_ePrint",
      "DBLP",
      "OpenAlex",
      "Semantic_Scholar",
      "arxiv_secondary",
      "google_scholar_fallback"
    ],
    "venue_priority": [
      "IACR ePrint",
      "ToSC/FSE",
      "CHES/TCHES",
      "CRYPTO",
      "EUROCRYPT",
      "ASIACRYPT",
      "Journal of Cryptology",
      "IACR Communications in Cryptology",
      "SAC",
      "INDOCRYPT",
      "AFRICACRYPT",
      "ACNS",
      "CANS",
      "ISC",
      "CT-RSA",
      "Designs, Codes and Cryptography",
      "Cryptography and Communications"
    ],
    "standardization_sources": [
      "NIST AES",
      "NIST SHA-3",
      "NIST Lightweight Cryptography",
      "CAESAR",
      "ISO/IEC",
      "IETF CFRG",
      "national standards",
      "official specifications and test vectors"
    ],
    "publication_status_labels": [
      "peer_reviewed",
      "eprint_or_preprint",
      "standard_or_specification",
      "technical_report",
      "book_or_chapter",
      "thesis",
      "slides",
      "artifact_or_code",
      "withdrawn_or_superseded",
      "unknown"
    ]
  },
  "model_profiles": {
    "openai_deep_reasoning": {
      "model": "openai/gpt-5.5",
      "auth_profile": "openai_codex_oauth_or_chatgpt_subscription",
      "intended_use": [
        "deep_reading",
        "planning",
        "reasoning",
        "drafting",
        "final_fresh_check"
      ]
    },
    "openai_code_agent": {
      "model": "openai/gpt-5.5",
      "runtime": "codex",
      "auth_profile": "openai_codex_oauth_or_chatgpt_subscription",
      "intended_use": [
        "code",
        "experiments",
        "debugging",
        "reproduction"
      ]
    },
    "deepseek_reviewer": {
      "model": "deepseek/deepseek-v4-pro",
      "auth_profile": "deepseek_api_key",
      "intended_use": [
        "independent_review",
        "claim_check",
        "complexity_audit",
        "overclaim_detection"
      ]
    },
    "deepseek_flash_worker": {
      "model": "deepseek/deepseek-v4-flash",
      "auth_profile": "deepseek_api_key",
      "optional": true,
      "intended_use": [
        "low_cost_rough_literature",
        "batch_extraction",
        "metadata_cleanup"
      ]
    },
    "openai_fresh_checker": {
      "model": "openai/gpt-5.5",
      "auth_profile": "openai_codex_oauth_or_chatgpt_subscription",
      "intended_use": [
        "fresh_context_final_check"
      ]
    }
  },
  "model_roles": {
    "main_researcher": "openai_deep_reasoning",
    "code_and_experiment_agent": "openai_code_agent",
    "independent_reviewer": "deepseek_reviewer",
    "optional_bulk_worker": "deepseek_flash_worker",
    "final_fresh_checker": "openai_fresh_checker"
  },
  "gate_policy": {
    "principle": "Gates block finalization and strong claims, not exploration, draft generation, or negative-result reporting.",
    "gate_levels": {
      "soft_gate": "continue in draft mode and record missing evidence",
      "review_gate": "requires independent reviewer or fresh-context checker",
      "hard_gate": "blocks final deliverables and paper-level claims but allows blocked reports, unverified drafts, and negative results"
    },
    "mode_interaction": {
      "human_in_the_loop": "hard gates pause for human confirmation",
      "supervised_auto": "hard gates pause when final claims or expensive experiments are affected",
      "overnight_auto": "hard gates create blocked reports and continue only with labeled draft/negative outputs",
      "full_auto_draft": "hard gates do not stop draft generation but forbid final-approved claim status"
    }
  },
  "claim_gates": {
    "require_literature_boundary": true,
    "require_primitive_or_component_profile": true,
    "require_claim_evidence_matrix": true,
    "require_independent_review": true,
    "require_complexity_audit_for_attacks": true,
    "require_reference_or_independent_validation_for_algorithm_claims": true,
    "require_modeling_assumptions_for_formal_model_claims": true,
    "require_scope_classification_for_cross_scope_items": true,
    "require_reproduction_or_validation_for_prior_attack_claims": true,
    "require_negative_results_recording": true,
    "block_strong_claims_without_evidence": true
  },
  "validation_policy": {
    "official_test_vectors_preferred": true,
    "official_test_vectors_required_when_available": true,
    "allow_independent_validation_when_test_vectors_missing": true,
    "minimum_independent_validation_methods": [
      "encrypt_decrypt_inverse_tests",
      "multiple_independent_implementations_agree",
      "known_intermediate_state_checks_from_spec_or_paper",
      "randomized_consistency_tests",
      "rederived_test_vectors_recorded_in_outputs"
    ],
    "missing_test_vector_policy": "do_not_block_automatically; downgrade_claim_confidence_and_record_validation_gap",
    "required_record_when_missing_test_vectors": "outputs/validation_gap_report.md"
  },
  "automation_policy": {
    "mode": "human_in_the_loop",
    "available_modes": [
      "human_in_the_loop",
      "supervised_auto",
      "overnight_auto",
      "full_auto_draft"
    ],
    "mode_presets": {
      "human_in_the_loop": {
        "auto_proceed": false,
        "human_checkpoint": true,
        "allow_auto_select_top_candidate": false,
        "max_autonomous_stage_depth": 1,
        "claim_output_status": "human_approved_only"
      },
      "supervised_auto": {
        "auto_proceed": true,
        "human_checkpoint": true,
        "allow_auto_select_top_candidate": true,
        "max_autonomous_stage_depth": 2,
        "claim_output_status": "draft_until_human_approved"
      },
      "overnight_auto": {
        "auto_proceed": true,
        "human_checkpoint": false,
        "allow_auto_select_top_candidate": true,
        "max_autonomous_stage_depth": 4,
        "claim_output_status": "draft_with_review_required",
        "require_review_gate_for_claims": true,
        "stop_on_claim_gate_failure": true,
        "write_blocked_report_instead_of_forcing_progress": true
      },
      "full_auto_draft": {
        "auto_proceed": true,
        "human_checkpoint": false,
        "allow_auto_select_top_candidate": true,
        "max_autonomous_stage_depth": null,
        "claim_output_status": "unverified_draft",
        "allow_paper_draft_generation": true,
        "allow_experiment_plan_generation": true,
        "allow_small_experiment_execution": true,
        "forbid_final_claim_status_without_human_or_final_checker": true,
        "write_risk_register": true
      }
    },
    "full_auto_draft_mode_allowed": true,
    "full_auto_draft_constraints": {
      "outputs_must_be_labeled_unverified": true,
      "final_deliverables_require_human_approval": true,
      "claim_gate_failures_block_finalization_not_drafting": true,
      "claim_gate_failures_become_negative_or_blocked_results": true,
      "reviewer_disagreement_blocks_finalization": true,
      "expensive_experiments_require_explicit_budget_or_prior_permission": true
    }
  },
  "experiment_auto_policy": {
    "allow_small_experiments_in_overnight_mode": true,
    "allow_small_experiments_in_full_auto_draft_mode": true,
    "allow_reference_tests_without_confirmation": true,
    "allow_randomized_validation_without_confirmation": true,
    "allow_small_milp_sat_smt_search_without_confirmation": true,
    "small_experiment_limits": {
      "max_runtime_minutes": 30,
      "max_memory_gb": 8,
      "max_cpu_threads": 8,
      "max_trials": 1000
    },
    "human_confirmation_required_for": [
      "expected_runtime_over_limit",
      "memory_over_limit",
      "full_key_space_search",
      "large_scale_exhaustive_search",
      "untrusted_external_code_execution",
      "global_dependency_installation",
      "network_access_beyond_literature_search",
      "api_cost_over_budget",
      "gpu_or_cluster_job_submission"
    ],
    "experiment_outputs_must_be_labeled": [
      "pilot",
      "small_scale_validation",
      "unverified_until_reviewed"
    ]
  },
  "budget": {
    "max_collected_sources": null,
    "max_candidate_papers": 120,
    "initial_deep_read_limit": 20,
    "allow_dynamic_deep_read_expansion": true,
    "max_search_rounds": 4,
    "max_review_rounds": 4,
    "max_ideation_candidates": 12,
    "max_experiment_hours": 6,
    "max_failed_attempts": 8,
    "api_cost_limit_usd": null,
    "prefer_subscription_models_when_available": true,
    "use_optional_low_cost_worker_for_bulk_tasks": false,
    "stop_on_claim_gate_failure": true,
    "claim_gate_failure_behavior": "block_finalization_but_allow_draft_and_blocked_report"
  },
  "sandbox": {
    "required": true,
    "sandbox_profile": "normal",
    "sandbox_profiles": {
      "safe": {
        "network_access": "literature_search_only",
        "dependency_install": "project_local_only_after_review",
        "allow_external_artifact_execution": false,
        "max_runtime_minutes_per_job": 30,
        "max_memory_gb_per_job": 8,
        "max_cpu_threads_per_job": 4
      },
      "normal": {
        "network_access": "literature_search_only",
        "dependency_install": "project_local_only",
        "allow_external_artifact_execution": "review_required",
        "max_runtime_minutes_per_job": 120,
        "max_memory_gb_per_job": 16,
        "max_cpu_threads_per_job": 8
      },
      "power": {
        "network_access": "declared_sources_only",
        "dependency_install": "project_local_only",
        "allow_external_artifact_execution": "review_required",
        "max_runtime_minutes_per_job": 720,
        "max_memory_gb_per_job": 32,
        "max_cpu_threads_per_job": 16,
        "requires_explicit_permission": true
      }
    },
    "sandbox_overrides_allowed": true,
    "sandbox_override_requires_reason": true,
    "sandbox_override_log": "pipeline/sandbox_override_log.md",
    "allowed_write_paths": [
      "configs/",
      "papers/",
      "knowledge/",
      "outputs/",
      "project/",
      "experiments/",
      "iterations/",
      "paper/",
      "deliverables/",
      "pipeline/",
      "logs/",
      "tmp/"
    ],
    "deny_paths": [
      "~/.ssh",
      "~/.aws",
      "~/.config",
      "~/.gnupg",
      "~/.kube",
      "/etc",
      "/var",
      "/root"
    ],
    "allow_global_install": false,
    "allow_untrusted_code_execution": false,
    "allow_network_access": "literature_search_only",
    "allow_dependency_install": "project_local_only",
    "require_virtual_environment_for_python": true,
    "require_review_before_running_external_artifacts": true
  },
  "required_outputs": [
    "pipeline/status.json",
    "outputs/source_registry.md",
    "outputs/scope_classification_log.md",
    "outputs/literature_search_matrix.md",
    "outputs/candidate_paper_queue.md",
    "outputs/primitive_profile.md",
    "outputs/component_property_profile.md",
    "outputs/attack_boundary_table.md",
    "outputs/claim_evidence_matrix.md",
    "outputs/modeling_assumptions.md",
    "outputs/validation_gap_report.md",
    "outputs/blocked_report.md",
    "outputs/risk_register.md",
    "outputs/research_log.md",
    "outputs/idea_candidates.md",
    "outputs/negative_results.md",
    "experiments/experiment_plan.md",
    "experiments/experiment_log.md",
    "iterations/lightweight_check_N.md",
    "iterations/review_round_N.md",
    "pipeline/human_checkpoints.md",
    "pipeline/sandbox_override_log.md"
  ],
  "notes": [
    "AES is an example target only; replace target fields in configs/config.sym.json for real projects.",
    "Strong claims require evidence, gates, and review; drafts and negative results may continue when gates fail.",
    "For source-code or formal-model results, document modeling assumptions before upgrading dependent claims."
  ]
}
